# ===========================
# PRODUCTION ENVIRONMENT
# FOR: Vercel + Railway (Recommended)
# ===========================

DEBUG=false
ENVIRONMENT=production

# ===== API Configuration =====
API_TITLE=ComplyIQ
API_VERSION=1.0.0
API_PREFIX=/api/v1

# Update with your Vercel frontend URL
CORS_ORIGINS=https://complyiq-production.vercel.app,https://your-custom-domain.com,chrome-extension://*

# ===== Database (Railway PostgreSQL) =====
# Railway will auto-generate this - copy from Railway dashboard
DATABASE_URL=postgresql://postgres:PASSWORD@container-name.railway.internal:5432/complyiq_db

# ===== Redis (Railway Redis) =====
# Railway will auto-generate this - copy from Railway dashboard
REDIS_URL=redis://:PASSWORD@container-name.railway.internal:6379/0

# ===== Celery Configuration =====
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# ===== Security =====
# IMPORTANT: Generate random 32+ character strings
# Use: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=generate-your-own-random-32-char-token-here
JWT_SECRET_KEY=generate-another-random-32-char-token-here

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Rate Limiting =====
# Stricter limits for production
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_PERIOD=60

# ===== OpenAI (Optional - for enhanced analysis) =====
OPENAI_API_KEY=sk-prod-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# ===== Scanning Configuration =====
# Use headless mode for production
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=30000
MAX_POLICY_LENGTH=100000
MAX_CONCURRENT_SCANS=10

# ===== NDPA Settings =====
NDPA_ENFORCEMENT=true
BVN_PATTERN_CHECK=true
NIN_PATTERN_CHECK=true

# ===== Logging =====
# Production: minimal logging
LOG_LEVEL=WARNING
LOG_FORMAT=json

# Optional: Sentry for error tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/your-project-id

# ===== Email Configuration (for notifications) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# ===== Database Backups =====
# Railway/DigitalOcean handles this automatically
BACKUP_RETENTION_DAYS=30

# ===== Backend URL (for internal communication) =====
# Used by extension and frontend
BACKEND_URL=https://your-backend-deployment-url.railway.app

# ===== Monitoring =====
ENABLE_MONITORING=true
ENABLE_AUDIT_LOGGING=true
