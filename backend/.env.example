# ===========================
# ComplyIQ Backend Configuration
# ===========================

# FastAPI
DEBUG=False
API_TITLE=ComplyIQ
API_VERSION=1.0.0
API_DESCRIPTION=Privacy & Compliance Intelligence Platform for Nigeria (NDPA)

# Database
DATABASE_URL=postgresql://complyiq:SecurePass2026!@postgres:5432/complyiq_db
SQLALCHEMY_ECHO=False

# Redis
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=86400  # 24 hours

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars-required
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# API Rate Limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_PERIOD=60  # seconds

# OpenAI (for privacy policy analysis - MVP only)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Scanning Configuration
PLAYWRIGHT_HEADLESS=True
PLAYWRIGHT_TIMEOUT=30000  # 30 seconds in milliseconds
MAX_POLICY_LENGTH=100000  # characters

# NDPA Compliance (Nigeria)
NDPA_ENFORCEMENT=True
BVN_PATTERN_CHECK=True
NIN_PATTERN_CHECK=True

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json  # json or text

# Deployment
ENVIRONMENT=development  # development, staging, production
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,chrome-extension://your-ext-id
